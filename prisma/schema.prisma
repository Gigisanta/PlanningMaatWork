// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// R&D COUNCIL LEADS - MaatWork + Cactus Wealth
// ============================================

model Lead {
  id           String    @id @default(cuid())
  name         String
  email        String
  company      String?
  phone        String?
  source       String    @default("web") // web, instagram, whatsapp, referral
  interest     String?   // "gym_audit", "cactus_wealth", "maatwork"
  stage        String    @default("new") // new, contacted, qualified, proposal, won, lost
  budgetScore  Int?      // 1-5
  urgencyScore Int?      // 1-5
  industryScore Int?     // 1-3
  totalScore   Int?      // 1-13
  notes        String?
  lastContact  DateTime?
  nextAction   String?
  nextActionDate DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  followUps    LeadFollowUp[]
}

model LeadFollowUp {
  id        String   @id @default(cuid())
  leadId    String
  type      String   // email, telegram, whatsapp, call
  status    String   // pending, sent, failed
  scheduledFor DateTime
  sentAt    DateTime?
  content   String?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id])
}
